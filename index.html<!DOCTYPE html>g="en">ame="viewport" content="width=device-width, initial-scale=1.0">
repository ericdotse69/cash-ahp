<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pro Cash Flow Tracker</title>
    <style>
        :root { --primary: #2563eb; --bg: #f8fafc; --card-bg: #ffffff; --text: #1e293b; --income: #16a34a; --expense: #dc2626; }
        body { font-family: sans-serif; background-color: var(--bg); color: var(--text); padding: 20px; display: flex; justify-content: center; }
        .container { width: 100%; max-width: 450px; }
        .dashboard, form, .history-container { background: var(--card-bg); padding: 20px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); margin-bottom: 20px; }
        h1 { font-size: 2em; margin: 10px 0; text-align: center;}
        .summary { display: flex; justify-content: space-between; }
        .summary div { width: 48%; text-align: center; padding: 10px; background: var(--bg); border-radius: 8px; }
        .form-control { margin-bottom: 12px; }
        input, select { width: 100%; padding: 10px; margin-top: 5px; border: 1px solid #cbd5e1; border-radius: 6px; box-sizing: border-box; }
        button { width: 100%; padding: 12px; border: none; border-radius: 6px; font-weight: bold; cursor: pointer; margin-top: 10px; }
        .btn-add { background: var(--primary); color: white; }
        .btn-export { background: #64748b; color: white; }
        .list { list-style: none; padding: 0; }
        .list li { background: #fff; border: 1px solid #e2e8f0; padding: 10px; margin-bottom: 8px; border-radius: 6px; display: flex; justify-content: space-between; align-items: center; border-left: 5px solid; }
        .plus { border-left-color: var(--income); }
        .minus { border-left-color: var(--expense); }
        .date-label { font-size: 0.75rem; color: #64748b; display: block; }
    </style>
</head>
<body>

<div class="container">
    <h2>Cash Flow Pro</h2>
    
    <div class="dashboard">
        <h4>TOTAL BALANCE</h4>
        <h1 id="balance">$0.00</h1>
        <div class="summary">
            <div><h4>INCOME</h4><p id="money-plus" style="color:var(--income)">+$0.00</p></div>
            <div><h4>EXPENSE</h4><p id="money-minus" style="color:var(--expense)">-$0.00</p></div>
        </div>
    </div>

    <form id="form">
        <div class="form-control"><label>Description</label><input type="text" id="text" placeholder="Salary, Rent..." required></div>
        <div class="form-control"><label>Amount</label><input type="number" id="amount" step="0.01" required></div>
        <div class="form-control"><label>Date & Time</label><input type="datetime-local" id="date" required></div>
        <div class="form-control">
            <label>Type</label>
            <select id="type"><option value="expense">Expense</option><option value="income">Income</option></select>
        </div>
        <button class="btn-add">Add Transaction</button>
    </form>

    <div class="history-container">
        <h3>History</h3>
        <label>Filter by Date:</label>
        <input type="date" id="filter-date" onchange="filterTransactions()">
        <ul id="list" class="list"></ul>
        <button class="btn-export" onclick="exportToCSV()">Export to Excel (CSV)</button>
    </div>
</div>

<script>
    const list = document.getElementById('list');
    const form = document.getElementById('form');
    let transactions = JSON.parse(localStorage.getItem('transactions')) || [];

    // Set default date to "now"
    document.getElementById('date').value = new Date().toISOString().slice(0, 16);

    function addTransaction(e) {
        e.preventDefault();
        const transaction = {
            id: Date.now(),
            text: document.getElementById('text').value,
            amount: document.getElementById('type').value === 'expense' ? -Math.abs(document.getElementById('amount').value) : Math.abs(document.getElementById('amount').value),
            date: document.getElementById('date').value
        };
        transactions.push(transaction);
        updateUI();
        form.reset();
        document.getElementById('date').value = new Date().toISOString().slice(0, 16);
    }

    function updateUI(filtered = transactions) {
        list.innerHTML = '';
        let inc = 0, exp = 0;
        filtered.sort((a,b) => new Date(b.date) - new Date(a.date)).forEach(t => {
            const item = document.createElement('li');
            item.classList.add(t.amount < 0 ? 'minus' : 'plus');
            item.innerHTML = `<div><span class="date-label">${t.date.replace('T', ' ')}</span><strong>${t.text}</strong></div> <span>$${Math.abs(t.amount).toFixed(2)}</span>`;
            list.appendChild(item);
            if(t.amount > 0) inc += t.amount; else exp += Math.abs(t.amount);
        });
        document.getElementById('balance').innerText = `$${(inc - exp).toFixed(2)}`;
        document.getElementById('money-plus').innerText = `+$${inc.toFixed(2)}`;
        document.getElementById('money-minus').innerText = `-$${exp.toFixed(2)}`;
        localStorage.setItem('transactions', JSON.stringify(transactions));
    }

    function filterTransactions() {
        const date = document.getElementById('filter-date').value;
        if(!date) return updateUI();
        const filtered = transactions.filter(t => t.date.startsWith(date));
        updateUI(filtered);
    }

    function exportToCSV() {
        let csv = 'Date,Description,Amount\n';
        transactions.forEach(t => { csv += `${t.date},${t.text},${t.amount}\n`; });
        const blob = new Blob([csv], { type: 'text/csv' });
        const url = window.URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'cash_flow_records.csv';
        a.click();
    }

    form.addEventListener('submit', addTransaction);
    updateUI();
</script>
</body>
</html>
